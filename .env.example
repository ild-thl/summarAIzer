# ==============================================================================
# ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to .env and update with your actual values
# IMPORTANT: Never commit .env to git - only .env.example is version controlled
#
# Note on Docker Compose:
#   - All variables from .env are loaded into containers
#   - SERVICE CONNECTION URLS (DATABASE_URL, CELERY_*, CHROMA_*) are overridden
#     by docker-compose.yml to use Docker service names (postgres, redis, chroma)
#   - This means you can use localhost URLs here for local development,
#     and Docker Compose will automatically switch to service names
# ==============================================================================

# Database
DATABASE_URL=postgresql://user:password@host:5432/database
DATABASE_ECHO=false

# API
API_TITLE="SummarAIzer API v2"
API_VERSION="2.0.0"
API_BASE_URL=http://localhost:7860

# Environment
ENVIRONMENT=development
DEBUG=true

# Security
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
# CORS
ENABLE_CORS=true
CORS_ORIGINS=["*"]

# JWT / Keycloak Authentication
# Set JWT_VERIFY_SIGNATURE=true in production.
JWT_VERIFY_SIGNATURE=true
JWT_VERIFY_EXP=true
JWT_ALGORITHMS=RS256
JWT_LEEWAY_SECONDS=30
JWT_AUDIENCE=
JWT_ISSUER=
JWT_JWKS_URL=
JWT_JWKS_CACHE_TTL_SECONDS=300
JWT_CLIENT_ID=

# Admin privilege mapping from JWT claims
JWT_ADMIN_ROLE=summaraizer_admin
JWT_ADMIN_GROUP=/admin

# Celery & Redis Configuration
# Using single Redis instance with database isolation
# Database 0: Celery message broker
# Database 1: Celery result backend
# Docker: Overridden to redis://redis:6379/0 and redis://redis:6379/1
# Local: Use localhost connection
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_TIMEOUT=3600

# LLM Configuration (OpenAI compatible endpoint expected)
LLM_API_KEY=sk-your-openai-api-key-here
LLM_MODEL=gemma-4-31b-it
LLM_MODEL_STRUCTURED_OUTPUT=qwen3-30b-a3b-instruct-2507
LLM_BASE_URL=https://chat-ai.academiccloud.de/v1

# Embedding Configuration
# Set to true to enable semantic search and embeddings (requires Chroma + embedding model)
ENABLE_EMBEDDINGS=false
# EMBEDDING_PROVIDER can be "openai" or "huggingface"
# - "openai": Uses OpenAI-compatible API (e.g., AcademicCloud)
# - "huggingface": Uses HuggingFace Inference API
EMBEDDING_PROVIDER=openai

# OpenAI Embeddings Configuration
EMBEDDING_MODEL_NAME=e5-mistral-7b-instruct
EMBEDDING_API_KEY=sk-your-openai-api-key-here
EMBEDDING_API_BASE_URL=https://chat-ai.academiccloud.de/v1
EMBEDDING_DIMENSION=4096

# Chroma Configuration for vector storage
# Docker: Overridden to http://chroma:8000 via docker-compose CHROMA_URL
# Local: Use localhost connection if running Chroma locally
# If using remote Chroma, set full URL here
CHROMA_URL=http://localhost:8000
CHROMA_CREDENTIALS=
CHROMA_PROVIDER=chromadb.auth.token_authn.TokenAuthClientProvider
CHROMA_TENANT=default_tenant

# Image Generation Configuration
IMAGE_GENERATION_API_URL=https://chat-ai.academiccloud.de/v1/images/generations
IMAGE_GENERATION_API_KEY=your-academic-cloud-api-key-here

# Docling Configuration
DOCLING_API_URL=https://chat-ai.academiccloud.de/v1/documents/convert
DOCLING_API_KEY=your-academic-cloud-api-key-here
DOCLING_REQUEST_TIMEOUT_SECONDS=180

# S3 bucket configuration for image storage
AWS_ACCESS_KEY_ID=00c9c977c194ed6f058e
AWS_SECRET_ACCESS_KEY=secret
AWS_DEFAULT_REGION=eu-central-2
AWS_BUCKET=dennis-dlc-dev
AWS_URL=https://dennis-dlc-dev.s3-eu-central-2.ionoscloud.com
AWS_ENDPOINT=https://s3-eu-central-2.ionoscloud.com
AWS_USE_PATH_STYLE_ENDPOINT=false

# Audio transcription configuration
AUDIO_FLAC_COMPRESSION_LEVEL=5
TRANSCRIBE_SEGMENT_SECONDS=170
TRANSCRIBE_MAX_FILE_SIZE_MB=25
TRANSCRIPTION_MODEL=whisper-large-v2
TRANSCRIPTION_RESPONSE_FORMAT=text
OPENAI_TRANSCRIBE_TEMPERATURE=0.4

# Matomo Configuration
MATOMO_ENABLED=false
MATOMO_URL=
MATOMO_SITE_ID=
MATOMO_TOKEN_AUTH=